<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="IStripperQuickPlayer.WinUI.PhotoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Photos"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" FontSize="16" Text="Loading photos..." />

        <GridView
            x:Name="PhotosGrid"
            Grid.Row="1"
            IsItemClickEnabled="True"
            ItemClick="PhotosGrid_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="160" Height="120">
                        <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Window>
